# Leave empty to use relative /api/v1 (Vite proxy). Or set origin only, e.g. http://127.0.0.1:8000
VITE_API_URL=
VITE_LINKEDIN_REDIRECT_URI=https://www.the-leadlab.com/linkedin/callback

# Optional: Supabase JS client (Vite requires VITE_ prefix — not NEXT_PUBLIC_)
# Project Settings → API: Project URL + anon (or publishable) key
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key
